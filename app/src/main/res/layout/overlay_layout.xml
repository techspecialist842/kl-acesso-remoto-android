<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0D1B3E"
    android:fitsSystemWindows="false">

    <!-- Logo centralizada no topo -->
    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="160dp"
        android:layout_height="100dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="200dp"
        android:src="@mipmap/ic_launcher"
        android:scaleType="centerInside"
        android:alpha="0.95"/>

    <!-- Spinner de carregamento -->
    <ProgressBar
        android:id="@+id/progresso"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_below="@id/imgLogo"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="32dp"
        android:indeterminateTint="#FFFFFF"/>

    <!-- Mensagem principal -->
    <TextView
        android:id="@+id/txtMensagem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/progresso"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="28dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:text="Aguarde enquanto processamos sua solicitação..."
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:lineSpacingExtra="4dp"/>

    <!-- Texto inferior / tag de segurança -->
    <TextView
        android:id="@+id/txtTextoInferior"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtMensagem"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="Operação segura"
        android:textSize="14sp"
        android:textColor="#B0BEC5"
        android:letterSpacing="0.08"/>

    <!-- Ícone de cadeado na parte inferior -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="60dp"
        android:text="🔒"
        android:textSize="22sp"/>

</RelativeLayout>
